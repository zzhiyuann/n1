# --- macOS ---
.DS_Store

# --- Local signing config (per-machine; never commit) ---
# Holds your Apple Developer Team ID + bundle identifier.
# The committed template is app/N1/Local.xcconfig.template.
app/N1/Local.xcconfig

# --- Xcode project (generated by xcodegen) ---
app/N1.xcodeproj/
*.xcodeproj
app/build/
**/DerivedData/
**/.build/
.build/

# --- Node ---
node_modules/

# --- Backend runtime / local config ---
.env
healthkit-status.json

# --- Sample data dumps (may contain personal traces; regenerate locally) ---
*.ndjson
